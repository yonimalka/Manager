{
  "cli": {
    "version": ">= 16.12.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SERVER_URL": "https://manager-production-1942.up.railway.app",
        "GOOGLE_IOS_CLIENT_ID": "YOUR_IOS_CLIENT_ID_HERE"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "distribution": "store",
        "image": "latest"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
